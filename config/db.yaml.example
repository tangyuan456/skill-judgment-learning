# yunyu_test_results 数据库连接配置示例
# 将本文件复制为 config/db.yaml 后填入真实凭据
# 也可通过环境变量覆盖：YUNYU_DB_HOST / YUNYU_DB_PORT / YUNYU_DB_NAME / YUNYU_DB_USER / YUNYU_DB_PASSWORD

yunyu_test_results:
  host: 9.30.x.x
  port: 5432
  database: yunyu
  user: readonly_user
  password: <CHANGE_ME>
  sslmode: disable
  pool_min: 1
  pool_max: 5
